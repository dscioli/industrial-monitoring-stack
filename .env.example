# Copy to .env and adjust. Never commit .env (it is gitignored).

# Grafana admin password (anonymous access is viewer-only)
GRAFANA_ADMIN_PASSWORD=change-me

# Host port for Grafana (3001 in the combined demo, where 3000 is the dashboard)
GRAFANA_PORT=3000

# Where Alertmanager POSTs alert notifications (any webhook receiver).
# Leave the placeholder if you have none: deliveries fail and are logged,
# nothing else breaks.
ALERT_WEBHOOK_URL=http://127.0.0.1:9095/no-op

# Timezone for dashboards
TZ=UTC
