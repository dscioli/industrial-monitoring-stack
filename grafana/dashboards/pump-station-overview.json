{
  "annotations": { "list": [] },
  "description": "Pump-station deep dive: connectivity, electrical faults, start/run counters, pump state, motor current. Metrics expose no station_type label, so the station selector derives pump stations as online stations minus those emitting collector_tank_level_cm (only tank sites emit it).",
  "editable": true,
  "graphTooltip": 1,
  "links": [],
  "panels": [
    {
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "description": "1 = a Modbus request was seen within the collector's offline timeout.",
      "fieldConfig": {
        "defaults": {
          "mappings": [
            {
              "type": "value",
              "options": {
                "0": { "text": "OFFLINE", "color": "red", "index": 0 },
                "1": { "text": "ONLINE", "color": "green", "index": 1 }
              }
            }
          ],
          "thresholds": { "mode": "absolute", "steps": [{ "color": "red", "value": null }] },
          "noValue": "no data"
        },
        "overrides": []
      },
      "gridPos": { "h": 4, "w": 4, "x": 0, "y": 0 },
      "id": 1,
      "options": {
        "colorMode": "background",
        "graphMode": "none",
        "justifyMode": "auto",
        "orientation": "auto",
        "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false },
        "textMode": "auto"
      },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "collector_station_online{station=\"$station\"}",
          "legendFormat": "online",
          "refId": "A"
        }
      ],
      "title": "Connectivity",
      "type": "stat"
    },
    {
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "description": "Age of the station's last Modbus request.",
      "fieldConfig": {
        "defaults": {
          "unit": "s",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "orange", "value": 60 },
              { "color": "red", "value": 180 }
            ]
          },
          "noValue": "never seen"
        },
        "overrides": []
      },
      "gridPos": { "h": 4, "w": 5, "x": 4, "y": 0 },
      "id": 2,
      "options": {
        "colorMode": "value",
        "graphMode": "area",
        "justifyMode": "auto",
        "orientation": "auto",
        "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false },
        "textMode": "auto"
      },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "collector_station_last_seen_seconds{station=\"$station\"}",
          "legendFormat": "last seen",
          "refId": "A"
        }
      ],
      "title": "Last seen",
      "type": "stat"
    },
    {
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "description": "Raw ALARM_BITS bitfield; anything above 0 means at least one latched electrical/process fault (per-bit labels live in the collector's station config).",
      "fieldConfig": {
        "defaults": {
          "mappings": [
            {
              "type": "value",
              "options": { "0": { "text": "NO FAULTS", "color": "green", "index": 0 } }
            },
            {
              "type": "range",
              "options": {
                "from": 1,
                "to": 63,
                "result": { "text": "FAULT", "color": "red", "index": 1 }
              }
            }
          ],
          "thresholds": { "mode": "absolute", "steps": [{ "color": "green", "value": null }] },
          "noValue": "no data"
        },
        "overrides": []
      },
      "gridPos": { "h": 4, "w": 5, "x": 9, "y": 0 },
      "id": 3,
      "options": {
        "colorMode": "background",
        "graphMode": "none",
        "justifyMode": "auto",
        "orientation": "auto",
        "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false },
        "textMode": "auto"
      },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "collector_alarm_bits{station=\"$station\"}",
          "legendFormat": "alarm bits",
          "refId": "A"
        }
      ],
      "title": "Electrical faults",
      "type": "stat"
    },
    {
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "description": "Pump start counter as reported by the station (wraps at 65535).",
      "fieldConfig": {
        "defaults": {
          "thresholds": { "mode": "absolute", "steps": [{ "color": "text", "value": null }] },
          "noValue": "n/a"
        },
        "overrides": []
      },
      "gridPos": { "h": 4, "w": 5, "x": 14, "y": 0 },
      "id": 4,
      "options": {
        "colorMode": "none",
        "graphMode": "none",
        "justifyMode": "auto",
        "orientation": "auto",
        "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false },
        "textMode": "auto"
      },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "collector_pump_start_count{station=\"$station\"}",
          "legendFormat": "starts",
          "refId": "A"
        }
      ],
      "title": "Pump starts",
      "type": "stat"
    },
    {
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "description": "Cumulative pump run time as reported by the station.",
      "fieldConfig": {
        "defaults": {
          "unit": "m",
          "thresholds": { "mode": "absolute", "steps": [{ "color": "text", "value": null }] },
          "noValue": "n/a"
        },
        "overrides": []
      },
      "gridPos": { "h": 4, "w": 5, "x": 19, "y": 0 },
      "id": 5,
      "options": {
        "colorMode": "none",
        "graphMode": "none",
        "justifyMode": "auto",
        "orientation": "auto",
        "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false },
        "textMode": "auto"
      },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "collector_pump_run_minutes{station=\"$station\"}",
          "legendFormat": "run minutes",
          "refId": "A"
        }
      ],
      "title": "Run time",
      "type": "stat"
    },
    {
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "description": "Contactor feedback over time.",
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "custom": { "fillOpacity": 70, "lineWidth": 0 },
          "mappings": [
            {
              "type": "value",
              "options": {
                "0": { "text": "Stopped", "color": "#9aa0a6", "index": 0 },
                "1": { "text": "Running", "color": "green", "index": 1 }
              }
            }
          ],
          "noValue": "no data"
        },
        "overrides": []
      },
      "gridPos": { "h": 9, "w": 12, "x": 0, "y": 4 },
      "id": 6,
      "options": {
        "alignValue": "left",
        "legend": { "displayMode": "list", "placement": "bottom", "showLegend": true },
        "mergeValues": true,
        "rowHeight": 0.8,
        "showValue": "auto",
        "tooltip": { "mode": "single", "sort": "none" }
      },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "collector_pump_running{station=\"$station\"}",
          "legendFormat": "pump",
          "refId": "A"
        }
      ],
      "transformations": [
        { "id": "filterFieldsByName", "options": { "include": { "pattern": ".+" } } }
      ],
      "title": "Pump state timeline",
      "type": "state-timeline"
    },
    {
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "description": "Motor current; the ~3 s start ramp and load noise are visible at the 15 s scrape resolution as steps.",
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "fixed", "fixedColor": "#E0B400" },
          "custom": {
            "drawStyle": "line",
            "fillOpacity": 12,
            "lineWidth": 2,
            "pointSize": 4,
            "showPoints": "never",
            "spanNulls": false
          },
          "min": 0,
          "unit": "amp"
        },
        "overrides": []
      },
      "gridPos": { "h": 9, "w": 12, "x": 12, "y": 4 },
      "id": 7,
      "options": {
        "legend": { "displayMode": "list", "placement": "bottom", "showLegend": false },
        "tooltip": { "mode": "single", "sort": "none" }
      },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "collector_motor_current_a{station=\"$station\"}",
          "legendFormat": "current",
          "refId": "A"
        }
      ],
      "title": "Motor current",
      "type": "timeseries"
    }
  ],
  "refresh": "15s",
  "schemaVersion": 39,
  "tags": ["aquaflow", "telemetry"],
  "templating": {
    "list": [
      {
        "current": {},
        "datasource": { "type": "prometheus", "uid": "prometheus" },
        "definition": "query_result(collector_station_online unless on(station) collector_tank_level_cm)",
        "includeAll": false,
        "label": "Station",
        "multi": false,
        "name": "station",
        "options": [],
        "query": "query_result(collector_station_online unless on(station) collector_tank_level_cm)",
        "regex": "/station=\"([^\"]+)\"/",
        "refresh": 2,
        "sort": 3,
        "type": "query"
      }
    ]
  },
  "time": { "from": "now-6h", "to": "now" },
  "timezone": "browser",
  "title": "Pump station overview",
  "uid": "pump-station-overview"
}
