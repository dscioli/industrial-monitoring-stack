{
  "annotations": { "list": [] },
  "description": "All stations at a glance: connectivity, pumps, tank levels, active alerts, Modbus traffic.",
  "editable": true,
  "graphTooltip": 1,
  "links": [],
  "panels": [
    {
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "description": "Stations currently online out of the configured fleet.",
      "fieldConfig": {
        "defaults": {
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "red", "value": null },
              { "color": "orange", "value": 2 },
              { "color": "green", "value": 3 }
            ]
          },
          "noValue": "collector down?"
        },
        "overrides": []
      },
      "gridPos": { "h": 4, "w": 8, "x": 0, "y": 0 },
      "id": 1,
      "options": {
        "colorMode": "background",
        "graphMode": "none",
        "justifyMode": "auto",
        "orientation": "auto",
        "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false },
        "textMode": "auto"
      },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "sum(collector_station_online)",
          "legendFormat": "online",
          "refId": "A"
        }
      ],
      "title": "Stations online",
      "type": "stat"
    },
    {
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "description": "Active alerts in the collector's own alert engine, all rule types.",
      "fieldConfig": {
        "defaults": {
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "red", "value": 1 }
            ]
          },
          "noValue": "0"
        },
        "overrides": []
      },
      "gridPos": { "h": 4, "w": 8, "x": 8, "y": 0 },
      "id": 2,
      "options": {
        "colorMode": "background",
        "graphMode": "none",
        "justifyMode": "auto",
        "orientation": "auto",
        "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false },
        "textMode": "auto"
      },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "sum(collector_alerts_active)",
          "legendFormat": "alerts",
          "refId": "A"
        }
      ],
      "title": "Active alerts",
      "type": "stat"
    },
    {
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "description": "Commands staged or awaiting confirmation; should return to 0 within seconds in normal operation.",
      "fieldConfig": {
        "defaults": {
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "orange", "value": 1 }
            ]
          },
          "noValue": "0"
        },
        "overrides": []
      },
      "gridPos": { "h": 4, "w": 8, "x": 16, "y": 0 },
      "id": 3,
      "options": {
        "colorMode": "background",
        "graphMode": "none",
        "justifyMode": "auto",
        "orientation": "auto",
        "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false },
        "textMode": "auto"
      },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "collector_commands_pending",
          "legendFormat": "pending",
          "refId": "A"
        }
      ],
      "title": "Pending commands",
      "type": "stat"
    },
    {
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "description": "Connect/disconnect churn per station — cellular links drop constantly; the question is whether they come back.",
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "custom": { "fillOpacity": 70, "lineWidth": 0 },
          "mappings": [
            {
              "type": "value",
              "options": {
                "0": { "text": "Offline", "color": "red", "index": 0 },
                "1": { "text": "Online", "color": "green", "index": 1 }
              }
            }
          ]
        },
        "overrides": []
      },
      "gridPos": { "h": 7, "w": 12, "x": 0, "y": 4 },
      "id": 4,
      "options": {
        "alignValue": "left",
        "legend": { "displayMode": "list", "placement": "bottom", "showLegend": true },
        "mergeValues": true,
        "rowHeight": 0.8,
        "showValue": "never",
        "tooltip": { "mode": "single", "sort": "none" }
      },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "collector_station_online",
          "legendFormat": "station {{station}}",
          "refId": "A"
        }
      ],
      "title": "Station connectivity",
      "type": "state-timeline"
    },
    {
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "description": "Contactor feedback per pump station.",
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "custom": { "fillOpacity": 70, "lineWidth": 0 },
          "mappings": [
            {
              "type": "value",
              "options": {
                "0": { "text": "Stopped", "color": "#9aa0a6", "index": 0 },
                "1": { "text": "Running", "color": "green", "index": 1 }
              }
            }
          ]
        },
        "overrides": []
      },
      "gridPos": { "h": 7, "w": 12, "x": 12, "y": 4 },
      "id": 5,
      "options": {
        "alignValue": "left",
        "legend": { "displayMode": "list", "placement": "bottom", "showLegend": true },
        "mergeValues": true,
        "rowHeight": 0.8,
        "showValue": "never",
        "tooltip": { "mode": "single", "sort": "none" }
      },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "collector_pump_running",
          "legendFormat": "station {{station}}",
          "refId": "A"
        }
      ],
      "title": "Pumps running",
      "type": "state-timeline"
    },
    {
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "description": "Filtered level of every tank site; dashed lines mark the demo control thresholds (180 / 420 cm).",
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "custom": {
            "drawStyle": "line",
            "fillOpacity": 0,
            "lineWidth": 2,
            "pointSize": 4,
            "showPoints": "never",
            "spanNulls": false,
            "thresholdsStyle": { "mode": "dashed" }
          },
          "min": 0,
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "transparent", "value": null },
              { "color": "orange", "value": 180 },
              { "color": "red", "value": 420 }
            ]
          },
          "unit": "suffix:cm"
        },
        "overrides": []
      },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 11 },
      "id": 6,
      "options": {
        "legend": { "displayMode": "list", "placement": "bottom", "showLegend": true },
        "tooltip": { "mode": "multi", "sort": "none" }
      },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "collector_tank_level_cm",
          "legendFormat": "station {{station}}",
          "refId": "A"
        }
      ],
      "title": "Tank levels (filtered)",
      "type": "timeseries"
    },
    {
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "description": "Identified Modbus requests per second, per station. Flat zero for one station = that station is silent; flat zero overall = the field side is down.",
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "custom": {
            "drawStyle": "line",
            "fillOpacity": 10,
            "lineWidth": 2,
            "pointSize": 4,
            "showPoints": "never",
            "spanNulls": false
          },
          "min": 0,
          "unit": "reqps"
        },
        "overrides": []
      },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 11 },
      "id": 7,
      "options": {
        "legend": { "displayMode": "list", "placement": "bottom", "showLegend": true },
        "tooltip": { "mode": "multi", "sort": "none" }
      },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "sum by (station) (rate(collector_modbus_requests_total[5m]))",
          "legendFormat": "station {{station}}",
          "refId": "A"
        }
      ],
      "title": "Modbus request rate",
      "type": "timeseries"
    },
    {
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "description": "Active alerts per rule type in the collector's alert engine.",
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "custom": {
            "drawStyle": "line",
            "fillOpacity": 25,
            "lineWidth": 1,
            "pointSize": 4,
            "showPoints": "never",
            "spanNulls": false,
            "stacking": { "group": "A", "mode": "normal" }
          },
          "min": 0
        },
        "overrides": []
      },
      "gridPos": { "h": 7, "w": 12, "x": 0, "y": 19 },
      "id": 8,
      "options": {
        "legend": { "displayMode": "list", "placement": "bottom", "showLegend": true },
        "tooltip": { "mode": "multi", "sort": "none" }
      },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "collector_alerts_active > 0 or collector_alerts_active * 0",
          "legendFormat": "{{type}}",
          "refId": "A"
        }
      ],
      "title": "Active alerts by type",
      "type": "timeseries"
    },
    {
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "description": "Blackbox TCP reachability of the collector's listeners (Modbus :1502, API :8080).",
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "custom": { "fillOpacity": 70, "lineWidth": 0 },
          "mappings": [
            {
              "type": "value",
              "options": {
                "0": { "text": "Unreachable", "color": "red", "index": 0 },
                "1": { "text": "Reachable", "color": "green", "index": 1 }
              }
            }
          ]
        },
        "overrides": []
      },
      "gridPos": { "h": 7, "w": 12, "x": 12, "y": 19 },
      "id": 9,
      "options": {
        "alignValue": "left",
        "legend": { "displayMode": "list", "placement": "bottom", "showLegend": true },
        "mergeValues": true,
        "rowHeight": 0.8,
        "showValue": "never",
        "tooltip": { "mode": "single", "sort": "none" }
      },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "probe_success{job=\"blackbox-tcp\"}",
          "legendFormat": "{{instance}}",
          "refId": "A"
        }
      ],
      "title": "Endpoint reachability (blackbox)",
      "type": "state-timeline"
    }
  ],
  "refresh": "15s",
  "schemaVersion": 39,
  "tags": ["aquaflow", "telemetry"],
  "templating": { "list": [] },
  "time": { "from": "now-6h", "to": "now" },
  "timezone": "browser",
  "title": "Fleet status",
  "uid": "fleet-status"
}
